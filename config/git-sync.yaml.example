version: 1

settings:
  state_dir: /app/state
  repo_dir: /app/repos
  log_level: INFO
  max_concurrent: 5
  default_schedule: "0 0 */7 * *"
  timezone: "Asia/Shanghai"
  unmapped_author_policy: warn

author_mappings:
  - match_email: "alice@personal.com"
    internal_name: "Alice Wang"
    internal_email: "alice.wang@internal.corp"
  - match_email: "bob@gmail.com"
    internal_name: "Bob Zhang"
    internal_email: "bob.zhang@internal.corp"

sync_tasks:
  - name: production-services
    description: "Production service repositories"
    schedule: "0 2 * * *"
    repos:
      - id: api-service
        github_url: git@github.com:org/api-service.git
        internal_url: git@git.internal.corp:mirrors/api-service.git
        branches: ["main", "release/*"]
        tags: true
        auth:
          type: ssh

      - id: web-frontend
        github_url: git@github.com:org/web-frontend.git
        internal_url: git@git.internal.corp:mirrors/web-frontend.git
        branches: ["main", "develop"]
        tags: false
        auth:
          type: ssh

  - name: internal-tools
    repos:
      - id: admin-dashboard
        github_url: git@github.com:org/admin-dashboard.git
        internal_url: git@git.internal.corp:mirrors/admin-dashboard.git
        branches: ["main"]
        tags: true
        auth:
          type: ssh
        author_mappings:
          - match_email: "dev@contractor.com"
            internal_name: "Contractor Dev"
            internal_email: "contractor.dev@internal.corp"
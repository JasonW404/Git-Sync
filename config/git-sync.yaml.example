version: 1

settings:
  state_dir: ./data/state
  repo_dir: ./data/repos
  log_level: INFO
  max_concurrent: 5
  default_schedule: "0 0 */7 * *"
  timezone: "Asia/Shanghai"
  unmapped_author_policy: warn

author_mappings:
  - match_email: "alice@personal.com"
    internal_name: "Alice Wang"
    internal_email: "alice.wang@internal.corp"
  - match_email: "bob@gmail.com"
    internal_name: "Bob Zhang"
    internal_email: "bob.zhang@internal.corp"

sync_tasks:
  - name: production-services
    description: "Production service repositories"
    schedule: "0 2 * * *"
    repos:
      - id: api-service
        source:
          url: git@github.com:org/api-service.git
          ssh_private_key: ~/.ssh/id_rsa_github
        destination:
          url: git@git.internal.corp:mirrors/api-service.git
          ssh_private_key: ~/.ssh/id_rsa_internal
        branches: ["main", "release/*"]
        tags: true

      - id: web-frontend
        source:
          url: https://github.com/org/web-frontend.git
        destination:
          url: https://git.internal.corp/mirrors/web-frontend.git
          username: sync-bot
          password: ${SYNC_PASSWORD}
        branches: ["main", "develop"]
        tags: false

      - id: open-source-mirror
        source:
          url: https://github.com/public-org/open-source-project.git
        destination:
          url: https://git.internal.corp/mirrors/open-source-project.git
          username: sync-bot
          password: ${SYNC_PASSWORD}
        branches: ["main"]
        tags: true

  - name: internal-tools
    repos:
      - id: admin-dashboard
        source:
          url: ssh://git@github.com:org/admin-dashboard.git
          ssh_private_key: ~/.ssh/id_ed25519
        destination:
          url: https://git.internal.corp/mirrors/admin-dashboard.git
          username: admin
          password: ${ADMIN_PASSWORD}
        branches: ["main"]
        tags: true
        author_mappings:
          - match_email: "dev@contractor.com"
            internal_name: "Contractor Dev"
            internal_email: "contractor.dev@internal.corp"
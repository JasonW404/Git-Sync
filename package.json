{
  "name": "git-sync",
  "version": "1.0.0",
  "type": "module",
  "description": "Sync GitHub repos to internal Git server with author rewriting",
  "main": "dist/cli.cjs",
  "types": "dist/cli.d.ts",
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=cjs --outfile=dist/cli.cjs && chmod +x dist/cli.cjs",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.cjs",
    "daemon": "node dist/cli.cjs daemon",
    "tui": "node dist/cli.cjs tui",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "git",
    "sync",
    "author-rewrite",
    "github",
    "mirror",
    "tui",
    "ink"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@types/cron": "^2.0.1",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cron": "^4.4.0",
    "date-fns": "^4.1.0",
    "execa": "^9.5.2",
    "ink": "^6.8.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "ora": "^8.1.1",
    "p-queue": "^8.0.1",
    "react": "^19.0.0",
    "simple-git": "^3.36.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^3.1.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "git-sync": "./dist/cli.js"
  }
}
